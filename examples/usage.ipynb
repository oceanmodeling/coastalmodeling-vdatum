    "# `coastalmodeling-vdatum` Usage Examples"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Online Vertical Datum Conversion"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from coastalmodeling_vdatum import vdatum
",
    "
",
    "lat = 30.197168
",
    "lon = -87.842459
",
    "z = 0.0
",
    "
",
    "# Convert from LMSL to MLLW
",
    "_, _, z_mllw = vdatum.convert("lmsl", "mllw", lat, lon, z, online=True)
",
    "print(f"Height in MLLW: {z_mllw:.3f} m")"
   ]
  }
